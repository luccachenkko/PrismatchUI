{
  "name": "shopify-price-match-batch-mvp",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check-prices": "tsx src/checkPrices.ts",
    "apply-approved": "tsx src/applyApproved.ts",
    "dev": "tsc && node dist/server.js",
    "dev:backend": "tsc && node dist/server.js",
    "frontend:install": "cd frontend && npm install",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "agent:dev": "tsx src/agent/telegramAgent.ts",
    "agent:start": "node dist/agent/telegramAgent.js",
    "scraper:test": "tsx scripts/testScraper.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev:all": "node scripts/devAll.mjs",
    "agent:telegram": "tsx src/agent/telegramAgent.ts"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
